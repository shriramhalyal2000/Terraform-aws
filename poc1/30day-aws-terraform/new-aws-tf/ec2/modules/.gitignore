*.tfstate
terraform
*.terraform
# Local .terraform directory (contains binaries and modules)
.terraform/

# .tfstate files (should be stored in a remote backend, not Git)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files as they often contain secrets
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override files for development (optional, uncomment if needed)
# !example_override.tf

# Include plugin cache directory
.terraform.lock.hcl

# Ignore CLI configuration files
.terraformrc
terraform.rc
